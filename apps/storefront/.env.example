# Storefront (Next.js) — variables de ejemplo
# Copiar a .env.local para desarrollo local

# URL pública de la app (opcional en dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS API (cuando el catálogo real esté conectado)
# NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001

# Supabase (Auth + datos núcleo — mismo proyecto que CMS)
# Local tras `pnpm db:start`: http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `supabase status`>

# Motor de precios (RF-007) — server-only para /api/pricing/resolve
# PRICING_ENGINE_ENABLED=true
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=<service_role from `supabase status`>
