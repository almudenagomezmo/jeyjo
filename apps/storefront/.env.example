# Storefront (Next.js) — variables de ejemplo
# Copiar a .env.local para desarrollo local

# URL pública de la app (opcional en dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS API (catálogo sincronizado desde ERP)
# Navegación global: árbol de categorías desde Payload REST (server-only)
# Home merchandising: global `home` (banners, categorías destacadas, carruseles) vía GET /api/globals/home?depth=2
# CMS_URL=http://localhost:3001
# Server-only: URL interna del CMS (no exponer secretos al cliente)
# CMS_INTERNAL_URL=http://localhost:3001
# NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001

# Qdrant vector search (predictive suggest + /search) — server-only
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Predictive search (RF-009): when false, /search uses CMS text filter only
# PREDICTIVE_SEARCH_ENABLED=true

# Supabase Auth + datos núcleo (mismo proyecto que CMS)
# Local tras `pnpm db:start`: http://127.0.0.1:54321
# Claves: `supabase status` (anon + service_role)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
# Server-only (registro/login, audit_log, perfiles — nunca en el cliente):
# SUPABASE_SERVICE_ROLE_KEY=<service_role key>

# B2B subusers RF-003: set false to bypass section permission guards (rollback only)
# B2B_PERMISSIONS_ENABLED=true

# Stock semáforo (RF-005) — server-only; no expone cantidades
# STOCK_LOW_THRESHOLD=5

# PLP facetada (RF-010): si el CMS no devuelve productos, usar catálogo demo local
# PLP_DEMO_FALLBACK=true

# Imágenes de catálogo (RF-024): dominios proveedor permitidos en next/image (coma-separados)
# CATALOG_IMAGE_REMOTE_HOSTS=example.com,cdn.distrisantiago.com,cdn.arnoia.com

# PDP (RF-012): restaura ficha demo con lib/data/products.ts si el CMS no está disponible
# PDP_USE_DEMO_DATA=true

# Carrito cliente (US-03) — resolución CMS en /api/catalog/cart-products
# CART_USE_CMS=true

# Motor de precios (RF-007) — server-only para /api/pricing/resolve y /api/pricing/batch
# PRICING_ENGINE_ENABLED=true
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=<service_role from `supabase status`>

# Checkout (US-04 / #17) — /checkout, prepare/place-order APIs
# CHECKOUT_ENABLED=true
# HMAC para token de resumen (recomendado en producción):
# CHECKOUT_SIGNING_SECRET=<random 32+ chars>
# CMS REST para crear pedidos (misma clave en apps/cms):
# CMS_INTERNAL_URL=http://localhost:3001
# STOREFRONT_PAYLOAD_API_KEY=<shared secret; Bearer en POST /api/orders>

# Presupuestos (US-05 / #19) — /presupuesto, APIs /api/quotes/*
# QUOTES_ENABLED=true
# NEXT_PUBLIC_QUOTES_ENABLED=true
# QUOTE_PREPARE_SECRET=<opcional; default CHECKOUT_SIGNING_SECRET o STOREFRONT_PAYLOAD_API_KEY>

# Pagos B2C (#18) — Redsys, PayPal, wallets
# PAYMENTS_ENABLED=true
# NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
# REDSYS_MERCHANT_CODE=<FUC>
# REDSYS_TERMINAL=001
# REDSYS_SECRET_KEY=<clave SHA256 Base64 del panel Redsys>
# REDSYS_ENV=test
# PAYPAL_CLIENT_ID=<sandbox client id>
# PAYPAL_CLIENT_SECRET=<sandbox secret>
# PAYPAL_ENV=sandbox
# CRON_SECRET=<opcional; protege GET /api/payments/redsys/reconcile>
# Notificaciones B2B: cron en CMS (invoice-sync, quote-expiry); portal usa campana + APIs intranet
# NOTIFICATIONS_ENABLED se configura en apps/cms/.env (no en storefront)
