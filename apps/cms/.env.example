# ─── Payload ────────────────────────────────────
PAYLOAD_SECRET=mygeneratedsecret
# Storefront checkout (#17): Bearer / x-jeyjo-storefront-key para POST /api/orders
# STOREFRONT_PAYLOAD_API_KEY=<same value as apps/storefront>

# ─── Base de Datos ──────────────────────────────
# Local (Docker)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/jeyjo
# Supabase — Session pooler (IPv4). Sustituye TU_PASSWORD por la contraseña del proyecto.
DATABASE_URL=postgresql://postgres.tqgrsofvlkyumagrqbqa:TU_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require
# Solo scripts CLI (seed:catalog, db:migrate) cuando el session pooler (5432) devuelve EMAXCONNSESSION.
# Opción A — Transaction pooler (IPv4, puerto 6543; recomendado si db.*.supabase.co no resuelve):
# DATABASE_URL_DIRECT=postgresql://postgres.tqgrsofvlkyumagrqbqa:TU_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Opción B — Direct connection (Supabase → Settings → Database):
# DATABASE_URL_DIRECT=postgresql://postgres.tqgrsofvlkyumagrqbqa:TU_PASSWORD@db.tqgrsofvlkyumagrqbqa.supabase.co:5432/postgres?sslmode=require
# Máx. conexiones por instancia de Payload (session pooler Supabase ~15 en total). Defecto 2; subir solo con Postgres local.
# PAYLOAD_DB_POOL_MAX=2
# En dev, Payload usa transaction pooler (:6543) automáticamente si DATABASE_URL apunta al session pooler (:5432).
# PAYLOAD_USE_SESSION_POOLER=true  # fuerza session pooler (puede agotar conexiones al guardar pedidos)
# PAYLOAD_USE_TX_POOLER=true       # fuerza transaction pooler también fuera de dev
# Dejar sin definir (o false). true solo en Postgres aislado sin tablas Supabase — push borraría customers/web_profiles.
# PAYLOAD_DB_PUSH=true

# ─── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# ─── Supabase (Auth / API — storefront; ver apps/storefront/.env.example) ───
SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
# Obligatorio en servidor para audit_log, search_events y consola de auditoría
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_solo_servidor

# ─── Staff MFA (backoffice) ─────────────────────
# Desarrollo: código MFA por email (RESEND_* o Mailpit). Producción: TOTP (Google Authenticator).
# Días sin exigir cookie MFA tras login (solo dev; 0 = obligatorio siempre)
MFA_GRACE_DAYS=0

# ─── Supabase Storage (S3) ──────────────────────
# Bucket alineado con supabase/migrations (catalog-media)
SUPABASE_BUCKET=catalog-media
SUPABASE_REGION=us-east-1
SUPABASE_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
SUPABASE_ACCESS_KEY_ID=tu_access_key_id_de_supabase
SUPABASE_SECRET_ACCESS_KEY=tu_secret_access_key_de_supabase

# ─── Qdrant (Base de datos vectorial) ──────────
# Local (Docker)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=tu_api_key_si_usas_qdrant_cloud
# SEARCH_RECONCILE_STALE_HOURS=2
# SEARCH_RECONCILE_ERROR_WINDOW_HOURS=24
# ORPHAN_CLEANUP_MAX_DELETES=500
# SEARCH_INDEX_ON_SAVE=false

# ─── Email ────────────────────────────────────────
# true = Mailpit (recomendado en local). false = Resend si hay RESEND_API_KEY.
# USE_MAILPIT=true
# MAILPIT_SMTP_HOST=localhost
# MAILPIT_SMTP_PORT=1025
# MAILPIT_WEB_URL=http://localhost:8025
# Levantar Mailpit: pnpm mailpit:up (desde la raíz del monorepo)
# Legacy: SMTP_USE_MAILPIT / SMTP_USE_RESEND (sustituidos por USE_MAILPIT)
RESEND_API_KEY=re_
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_FROM_EMAIL=noreply@tudominio.com
RESEND_FROM_NAME="Jeyjo"

# ─── ERP integration (ports / adapters — change #4, #29) ───
# stub = datos demo locales; excel = ImportaciónArticulos.xlsx (#29); api = #36
ERP_ADAPTER=stub
# Ruta al último ImportaciónArticulos.xlsx para cron con ERP_ADAPTER=excel
# ERP_EXCEL_CATALOG_PATH=/path/to/ImportaciónArticulos.xlsx
# Referencias comodín excluidas del catálogo público (RF-006)
# ERP_WILDCARD_SKUS=9000000001
# Secreto para cron Vercel: GET /api/cron/erp-catalog-sync con Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=genera-un-secreto-largo-aleatorio

# ─── Modo operativo web-native (sin ERP) ───
# Por defecto true: catálogo/stock/documentos/tarifas gestionados desde CMS.
# WEB_NATIVE_MODE=true
# Con web-native activo, los crons erp-catalog-sync y stock-sync responden 410.

# ─── Stock multisource (change #8) ───
# stub = fixtures REF-001..004; ftp / web = wiring futuro
STOCK_DISTRI_ADAPTER=stub
STOCK_ARNOIA_ADAPTER=stub
# Umbral "últimas unidades" (CA-ERP-001); fallback si CMS no disponible — configurar en /admin/system-config
# STOCK_LOW_THRESHOLD=5
# CATALOG_STALENESS_HOURS=24
# Cron: GET /api/cron/stock-sync (mismo CRON_SECRET)
# Cron: GET /api/cron/search-indexer cada minuto (indexación Qdrant RF-009)
# Cron: GET /api/cron/search-reconcile cada hora (reconciliación catálogo ↔ Qdrant)
# Cron: GET /api/cron/search-orphan-cleanup diario 04:00 UTC (limpieza huérfanos Qdrant)
# Cron: GET /api/cron/invoice-sync cada 5 min (RF-022 facturas, requiere NOTIFICATIONS_ENABLED)
# Cron: GET /api/cron/quote-expiry-notifications diario 07:00 UTC (RF-022c)
# Cron: GET /api/cron/abandoned-cart cada 15 min (US-23)
# Cron: GET /api/cron/coupon-expiry diario 06:00 UTC (US-18 CA4)
# CART_RECOVER_SECRET=<misma clave que apps/storefront; enlaces email recuperación>

# ─── B2B notifications (change #28) ───
# NOTIFICATIONS_ENABLED=true
# Wishlist stock alerts (#35) — post stock-sync; desactivar con false
# WISHLIST_STOCK_ALERTS_ENABLED=true

# Checkout storefront → POST /api/orders (Bearer)
# STOREFRONT_PAYLOAD_API_KEY=<shared secret with apps/storefront>

# Global Payload `paymentSettings` (métodos B2C activables sin redeploy)

# Dashboard KPIs (#30) — US-19 / RF-026; fallbacks si CMS no disponible — ver /admin/system-config
# TZ=Europe/Madrid
# DASHBOARD_LOW_STOCK_THRESHOLD=5
# TOP_SALES_WINDOW_DAYS=30

# Configuración operativa (#42) — Alcance §1.36
# Hub: /admin/system-config | Global: systemSettings | API pública: GET /api/system/config
# Portes, umbrales stock/alertas y contacto se editan en Payload; env vars anteriores son fallback.

# SKAI / EVA (#32) — RI-005, US-20, US-22
# SKAI_ADAPTER=stub
# SKAI_API_URL=https://api.skai.example/v1
# SKAI_API_KEY=
# SKAI_WIDGET_ID=eva-jeyjo
# SKAI_WIDGET_SCRIPT_URL=
# SKAI_WEBHOOK_SECRET=<random secret for POST /api/eva/orders>
# EVA_CONTEXT_JWT_SECRET=<shared with apps/storefront; JWT context 15 min>

# Newsletter (#newsletter-subscription) — suscripción footer + Brevo sync
# NEWSLETTER_INTERNAL_SECRET=<shared with apps/storefront>
# STOREFRONT_URL=http://localhost:3000
# BREVO_API_KEY=
# BREVO_NEWSLETTER_LIST_ID=

# Google Analytics 4 y Merchant Center feed (#34) — RF-028 / RI-008
# MERCHANT_FEED_ENABLED=true
# MERCHANT_FEED_BASE_URL=http://localhost:3000
# Feed público: GET /api/feeds/merchant-center.xml
# Cron diario: GET /api/cron/merchant-feed (Authorization: Bearer $CRON_SECRET)
# GA4 measurement ID en storefront: NEXT_PUBLIC_GA4_MEASUREMENT_ID

# ─── App ────────────────────────────────────────
COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
PREVIEW_SECRET=demo-draft-secret
