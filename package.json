{
  "name": "jeyjo-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "Jeyjo Digital Platform — monorepo (storefront + Payload CMS)",
  "scripts": {
    "dev": "pnpm --parallel --filter @jeyjo/storefront --filter @jeyjo/cms dev",
    "dev:storefront": "pnpm --filter @jeyjo/storefront dev",
    "dev:cms": "pnpm --filter @jeyjo/cms dev",
    "build": "pnpm -r build",
    "build:storefront": "pnpm --filter @jeyjo/storefront build",
    "build:cms": "pnpm --filter @jeyjo/cms build",
    "lint": "pnpm --filter @jeyjo/storefront lint",
    "lint:all": "pnpm -r lint",
    "typecheck": "pnpm --filter @jeyjo/database-types typecheck && pnpm --filter @jeyjo/erp-ports typecheck && pnpm --filter @jeyjo/stock-ports typecheck && pnpm --filter @jeyjo/pricing typecheck && pnpm --filter @jeyjo/search-embedding typecheck && pnpm --filter @jeyjo/storefront typecheck && pnpm --filter @jeyjo/cms typecheck",
    "format": "pnpm --filter @jeyjo/storefront format",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push --linked",
    "db:check-schema": "node scripts/check-supabase-schema.mjs",
    "db:apply-migrations": "node scripts/apply-migrations-pg.mjs",
    "db:repair-migrations": "node scripts/apply-migrations-pg.mjs --reset-history",
    "db:sql-editor-bundle": "node scripts/generate-sql-editor-bundle.mjs",
    "db:seed": "node scripts/apply-seed-sql.mjs",
    "seed:catalog": "pnpm --filter @jeyjo/cms seed:catalog",
    "sync:categories": "pnpm --filter @jeyjo/storefront sync:categories",
    "db:bootstrap": "pnpm db:seed && pnpm seed:catalog",
    "db:bootstrap:local": "pnpm db:reset && pnpm seed:catalog",
    "db:types": "node scripts/generate-database-types.mjs",
    "db:types:check": "node scripts/check-database-types.mjs",
    "mailpit:up": "docker compose -f apps/cms/docker/docker-compose.yml up -d mailpit",
    "mailpit:down": "docker compose -f apps/cms/docker/docker-compose.yml stop mailpit"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "pg": "^8.21.0"
  }
}
